{
  "name": "@comind/core",
  "version": "0.1.0",
  "description": "A portable cognitive layer for AI agents — intention-driven memory recall, a typed meaning layer (artifacts), provenance, and an inspectable agent runtime. Bring your own store, embeddings, and LLM.",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synthonyai/comind.git"
  },
  "keywords": [
    "ai",
    "agents",
    "memory",
    "llm",
    "embeddings",
    "rag",
    "cognitive-architecture",
    "agent-runtime"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "demo:prove": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register demo/proveBoundary.ts",
    "demo:check": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register demo/checkBarrelClean.ts",
    "demo:play": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register demo/play.ts",
    "demo:tui": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register demo/play.ts --tui",
    "demo:step": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register demo/play.ts --tui --step",
    "demo:repl": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register demo/repl.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.23",
    "ai": "^4.3.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "chalk": "^4.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^3.15.0",
    "typescript": "^5"
  }
}
