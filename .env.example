# ===========================================
# CoMind Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ----- Database -----
# PostgreSQL with pgvector extension required
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/comind"

# ----- Authentication (NextAuth) -----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ----- OpenAI -----
# Used for LLM calls (gpt-4o) and transcription
OPENAI_API_KEY="sk-..."

# ----- Embeddings -----
# HuggingFace Inference API (current)
HUGGINGFACE_API_KEY="hf_..."
