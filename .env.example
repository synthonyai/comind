# ===========================================
# CoMind Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
#
# CoMind is backend-agnostic: you bring a store, an embedder, and an LLM. These
# keys are only needed for the batteries-included provider adapters. The offline
# demo (npm run demo:play -- --offline) and the characterization suite need NONE.

# ----- LLM (OpenAILLMProvider) -----
# Used by the default OpenAI adapter for the agent runtime.
OPENAI_API_KEY="sk-..."

# ----- Embeddings (huggingFaceEmbeddingProvider) -----
# Only needed if you use the HuggingFace embedding adapter (BAAI/bge-large-en-v1.5).
HUGGINGFACE_API_KEY="hf_..."
